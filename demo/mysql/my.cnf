[mysqld]
# Binlog settings required by bintrail
server-id               = 1
log-bin                 = mysql-bin
binlog-format           = ROW
binlog-row-image        = FULL
binlog-expire-logs-seconds = 0

# GTID — enables --start-gtid in bintrail stream
gtid-mode               = ON
enforce-gtid-consistency = ON

# Required when using triggers + GTID mode
log-bin-trust-function-creators = 1

# Use mysql_native_password so the MariaDB CLI client in Alpine can authenticate.
# caching_sha2_password (MySQL 8.0 default) is not supported by mariadb-client.
default-authentication-plugin = mysql_native_password

# Performance
innodb-buffer-pool-size = 256M
max-connections         = 200
