# ── RDS (source database) ────────────────────────────────────────────────
RDS_ENDPOINT=your-rds.abc123.us-east-1.rds.amazonaws.com
RDS_USER=admin
RDS_PASSWORD=your-rds-master-password

# ── Index MySQL on EC2 (Percona Server) ──────────────────────────────────
INDEX_HOST=<private-ip-of-index-ec2>
INDEX_USER=bintrail
INDEX_PASSWORD=your-index-password

# ── bintrail settings ────────────────────────────────────────────────────
SCHEMAS=demo,sbtest
SERVER_ID=99999
BATCH_SIZE=500
CHECKPOINT=5
