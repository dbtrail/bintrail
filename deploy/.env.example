# ── RDS (source database) ────────────────────────────────────────────────
RDS_ENDPOINT=your-rds.abc123.us-east-1.rds.amazonaws.com

# bintrail stream (replication reader)
BINTRAIL_RDS_USER=bintrail_reader
BINTRAIL_RDS_PASSWORD=your-bintrail-reader-password

# traffic generator (DML only)
TRAFFIC_RDS_USER=traffic
TRAFFIC_RDS_PASSWORD=your-traffic-password

# ── Index MySQL on EC2 (Percona Server) ──────────────────────────────────
INDEX_HOST=<private-ip-of-index-ec2>
INDEX_USER=bintrail
INDEX_PASSWORD=your-index-password

# ── Grafana ───────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=your-grafana-admin-password

# ── bintrail settings ────────────────────────────────────────────────────
SCHEMAS=demo,sbtest
SERVER_ID=99999
BATCH_SIZE=500
CHECKPOINT=5
