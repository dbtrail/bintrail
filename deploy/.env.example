RDS_USER=admin
RDS_PASSWORD=your-rds-master-password

# ── bintrail settings ──────────────────────────────────────────────────────
SCHEMAS=demo,sbtest
SERVER_ID=99999
BATCH_SIZE=500
CHECKPOINT=5
